# ─── Branding ────────────────────────────────────────────────────────────────
# Shown in bot messages, dashboard header, email subjects, etc.
APP_NAME="Sales Coach"
COMPANY_NAME="Your Company"

# ─── Telegram (required) ─────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional: bot username without @ (e.g. YourCoachBot), used for invite links
TELEGRAM_BOT_USERNAME=

# ─── LLM (OpenAI required, Anthropic optional fallback) ──────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Optional models — defaults are gpt-4o-mini + whisper-1
# OPENAI_GRADING_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1

# Optional
ANTHROPIC_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Dev: SQLite works fine
DATABASE_URL=sqlite:///sales_coach.db
# Prod: PostgreSQL recommended
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Dashboard (required for web UI) ─────────────────────────────────────────
# Any random long string — used to sign Flask sessions
SECRET_KEY=change-this-to-a-random-string
# Login password for the admin dashboard at /login
ADMIN_PASSWORD=change-this-admin-password
# Bind address for the Flask app
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
# Public URL of your deployment — used in email links and redemption URLs
# BASE_URL=https://your-app.railway.app

# ─── Admin Telegram (required for admin commands) ────────────────────────────
# Comma-separated Telegram chat IDs that can use /resumen, /yesterday, receive
# feedback alerts, redemption notifications, etc.
# To find your chat_id: send /start to your bot and check the bot logs.
ADMIN_CHAT_ID=
MANAGER_ALERT_CHAT_IDS=

# ─── Products / services your team sells ─────────────────────────────────────
# Comma-separated tags that classify questions and user specializations.
# These become filter options in the dashboard.
VALID_SERVICES=product_a,product_b,general

# ─── Countries (for multi-timezone scheduling) ───────────────────────────────
# Comma-separated country codes. "all" is a special value meaning any country.
COUNTRIES=all,mexico,colombia,chile,peru

# ─── Enrollment (optional) ───────────────────────────────────────────────────
# If set, restricts self-enrollment to emails ending in @<domain>
# ENROLL_EMAIL_DOMAIN=yourcompany.com
# Shared enrollment code (single link for whole team; admin approves each user)
ENROLL_CODE=enroll

# ─── Bot behavior ────────────────────────────────────────────────────────────
DAILY_QUESTIONS_COUNT=5
DAILY_QUESTIONS_MAX=10
MAX_PROBES_PER_QUESTION=3
ANTI_REPEAT_DAYS=7
REMINDER_HOURS=4
INACTIVITY_ALERT_DAYS=3

# Spaced repetition — wrong answers re-sent after these day intervals
SR_REVIEW_INTERVALS=3,7,14
SR_MAX_REVIEWS_PER_DAY=2

# ─── Weekly email report (optional) ──────────────────────────────────────────
# Preferred path: Resend (HTTPS, works from most hosts including Railway)
# Get from resend.com/api-keys
RESEND_API_KEY=
# Verified sender address in Resend (must be from a verified domain, or use
# onboarding@resend.dev for testing sending to yourself only)
WEEKLY_REPORT_EMAIL_FROM=
# Comma-separated recipients. Leave empty to skip weekly email.
WEEKLY_REPORT_EMAIL_RECIPIENTS=
WEEKLY_REPORT_EMAIL_ENABLED=true

# Alternative path: SMTP (only works if your host allows SMTP egress)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=25

# ─── Scoring ─────────────────────────────────────────────────────────────────
ENABLE_SPIN_EVALUATION=true
ENABLE_CHALLENGER_EVALUATION=true
SHOW_BONUS_SCORES_TO_REPS=false
# Difficulty progression: adapt questions to individual rep skill.
# Disabled by default so leaderboard is apples-to-apples.
ENABLE_DIFFICULTY_PROGRESSION=false
DIFFICULTY_LOOKBACK_DAYS=14

# ─── Runtime ─────────────────────────────────────────────────────────────────
ENV=development
DEBUG=true
